# Copy to .env (and keep it out of git). Or set these in your host's dashboard.

# Identity provider: auto | simulated | stripe | persona
TANGIBLE_IDENTITY_PROVIDER=auto

# Notary provider: auto | simulated | pandadoc
TANGIBLE_NOTARY_PROVIDER=auto

# Payment rail for pay+proof: auto | simulated | stripe  (default: simulated via auto)
# "auto" uses Stripe when STRIPE_API_KEY is set, otherwise the no-keys
# SimulatedRail so the first pay() returns a real signed receipt with no account.
# STRIPE_API_KEY (below) is reused for the live rail.
PROVENANT_RAIL=auto

# Pay mode is driven by the public-key prefix passed to the SDK/API (Decision 13):
#   pk_test_... -> simulated / Stripe-test, receipt stamped mode:"test"
#   pk_live_... -> live rail,               receipt stamped mode:"live"

# Stripe Identity. Leave unset to run simulated. Test key (sk_test_...) is free.
# STRIPE_API_KEY=sk_test_xxx

# Set after you create the Stripe webhook (whsec_...). Optional for polling-only.
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# Persona Identity. Leave unset to run simulated. Sandbox key is free.
# Sign up at https://withpersona.com to get a key.
# Create an inquiry template at https://app.withpersona.com/dashboard
# PERSONA_API_KEY=persona_sandbox_xxx
# PERSONA_TEMPLATE_ID=itmpl_xxx

# PandaDoc Notary. Leave unset to run simulated. Sandbox key is free.
# PANDADOC_API_KEY=your_sandbox_api_key
